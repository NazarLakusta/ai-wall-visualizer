# Application
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production
JWT_SECRET=change-me-jwt-secret
JWT_EXPIRE_MINUTES=60

# Database
DATABASE_URL=postgresql+asyncpg://wallviz:wallviz@postgres:5432/wallviz
DATABASE_URL_SYNC=postgresql://wallviz:wallviz@postgres:5432/wallviz

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Telegram — отримайте токен у @BotFather (ніколи не комітьте реальний токен)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
WEBAPP_URL=http://localhost/app
INTERNAL_API_URL=http://api:8000

# Storage
STORAGE_PATH=/app/storage
RETENTION_HOURS=36
MAX_UPLOAD_MB=20

# AI
TORCH_NUM_THREADS=2
SAM_CHECKPOINT_PATH=/app/models/mobile_sam.pt
MAX_IMAGE_SIZE=1024
WALL_CONFIDENCE_THRESHOLD=0.85
SEGFORMER_MODEL_ID=nvidia/segformer-b5-finetuned-ade-640-640

# Admin seed (development only — змініть перед продакшеном)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-before-production
PLATFORM_ADMIN_EMAIL=super@example.com
PLATFORM_ADMIN_PASSWORD=change-me-before-production
DEFAULT_STORE_NAME=Demo Store
DEFAULT_STORE_SLUG=demo

# Launch / AI queue (set AI_WORKER_COUNT = number of celery worker containers)
AI_WORKER_COUNT=3
AVG_PROCESSING_SECONDS=45
MAX_AI_QUEUE=120

# Ops monitor — ваш приватний Telegram-бот (сповіщення про сервер)
# 1) Створіть бота в @BotFather
# 2) Напишіть йому /start — сервіс ops покаже ваш Chat ID
# 3) Заповніть змінні нижче і: docker compose up -d ops
OPS_TELEGRAM_BOT_TOKEN=
OPS_TELEGRAM_CHAT_ID=
OPS_HEARTBEAT_INTERVAL_MINUTES=15
OPS_QUEUE_WARN_THRESHOLD=10
OPS_QUEUE_CRITICAL_THRESHOLD=30
